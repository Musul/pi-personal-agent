{
  "name": "pi-tool-backup",
  "version": "2.0.0",
  "type": "tool",
  "description": "Backup/restore bundle for pi-mono based agent systems. Excludes node_modules, splits archives >45MB to fit Telegram.",
  "entry": "./pi-backup.sh",
  "reads": [
    "~/workspace/",
    "~/pi-system/extensions/",
    "~/pi-system/docs/",
    "~/pi-system/scripts/",
    "~/.pi/agent/settings.json",
    "~/.pi/agent/telebridge.json",
    "~/.pi/agent/pi-cron.tab"
  ],
  "writes": [
    "~/pi-system/logs/backups/"
  ],
  "consumes_events": [],
  "emits_events": [
    "backup:completed"
  ],
  "depends_on": [],
  "env": [
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_CHAT_ID",
    "PI_BACKUP_MAX_MB"
  ],
  "cli": {
    "backup": "bash ~/pi-system/extensions/pi-tool-backup/pi-backup.sh [--transfer|--full|--local-only]",
    "restore": "bash ~/pi-system/extensions/pi-tool-backup/restore.sh <archive.tar.gz> [--install-deps]"
  },
  "user_docs": "~/workspace/AGENTS.md#backup-de-instancia"
}
