# ============================================
# PI AGENT — ENVIRONMENT TEMPLATE
# ============================================
# 1. Copy this file to ~/.env
# 2. Replace placeholders with real values
# 3. NEVER commit your real .env — .gitignore already excludes it

# ─── LLM provider ──────────────────────────
export MOONSHOT_API_KEY="sk-kimi-..."

# ─── Web research ──────────────────────────
export TAVILY_API_KEY="tvly-dev-..."
# Optional: route Tavily through a Cloudflare Worker to bypass WAF blocks
# from some regions. See pi-system/extensions/pi-tool-tavily/worker/README.md.
# Leave unset to hit api.tavily.com directly.
# export TAVILY_PROXY_URL="https://tavily-proxy.<your-subdomain>.workers.dev"

# ─── Telegram (channel + backup) ───────────
export TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
export TELEGRAM_CHAT_ID="12345678"

# ─── Voice (STT / TTS) ─────────────────────
export ELEVENLABS_API_KEY="sk_..."

# ─── Pi agent config ───────────────────────
export PI_HOME="/data/data/com.termux/files/home"
export PI_WORKSPACE="$PI_HOME/workspace"

# ─── Backup knobs ──────────────────────────
# Include ~/.env in backup bundle. Default: false.
# Only enable if the destination is 100% trusted.
export PI_BACKUP_INCLUDE_ENV="false"
# Split size per part in MB when archive > this (Telegram limit ~50MB).
export PI_BACKUP_MAX_MB="45"

# ─── Finance data dir override (optional) ──
# Defaults to $PI_HOME/workspace/finanzas if unset.
# export FINANZAS_DATA_DIR="$PI_HOME/workspace/finanzas"

# ─── Finance FX config (optional) ──────────
# Secondary-currency support is OFF by default (pure USD mode).
# To enable, set FX_ENABLED=true and provide a JSON endpoint that returns a
# numeric rate (units of secondary currency per 1 USD).
# Examples (illustrative — pick whatever applies in your locale):
#   FX_API_URL="https://api.exchangerate.host/latest?base=USD&symbols=EUR" + FX_LABEL="ECB" + FX_SYMBOL="€"
#   FX_API_URL="<your-rate-provider>" + FX_LABEL="<source>" + FX_SYMBOL="<symbol>"
# export FX_ENABLED="false"
# export FX_API_URL=""
# export FX_LABEL="FX"
# export FX_SYMBOL=""


# ============================================
# MIGRATION TO A NEW PHONE
# ============================================
#
# 1. INSTALL TERMUX (from F-Droid, NOT Google Play)
#    https://f-droid.org/packages/com.termux/
#
# 2. BASE DEPENDENCIES
#    pkg update && pkg install nodejs-lts git poppler tesseract curl
#    npm install -g @mariozechner/pi-coding-agent
#
# 3. RESTORE BACKUP
#    Download the .tar.gz from Telegram (reassemble parts if split):
#      cat pi-backup-transfer-*.part.* > pi-backup-transfer.tar.gz
#    Then:
#      bash pi-system/extensions/pi-tool-backup/restore.sh pi-backup-transfer.tar.gz --install-deps
#    This extracts ~/workspace, ~/pi-system, and minimal ~/.pi/agent config,
#    and runs `npm install` in every extension that has a package.json.
#
# 4. RECOVER THIS FILE
#    If PI_BACKUP_INCLUDE_ENV=true, ~/.env is already in the bundle.
#    Otherwise copy this .env.example to ~/.env and fill in values.
#
# 5. POPULATE FORKS (only if restore.sh didn't)
#    bash ~/pi-system/scripts/migrate.sh --apply
#    This copies kimicodeprovider and @e9n/pi-cron sources into
#    pi-system/extensions/pi-provider-kimi and pi-cron-forked,
#    renames the packages, and installs their deps.
#
# 6. SET MODE
#    User (customer-ready, pi-system is read-only):
#      bash ~/pi-system/scripts/set-mode.sh user
#    Developer (you can modify extensions):
#      bash ~/pi-system/scripts/set-mode.sh dev
#
# 7. HOME-SCREEN WIDGET (optional)
#    a) Install Termux:Widget from F-Droid:
#       https://f-droid.org/packages/com.termux.widget/
#    b) Patch pi shebang so the widget can spawn it:
#       pkg install which -y
#       termux-fix-shebang $(which pi)
#    c) mkdir -p ~/.shortcuts
#    d) Create ~/.shortcuts/pi.sh:
#
#       #!/data/data/com.termux/files/usr/bin/bash
#       source "$HOME/.env"
#       termux-wake-lock
#       cd "$PI_WORKSPACE" || cd ~/workspace || exit 1
#       pi
#
#    e) chmod +x ~/.shortcuts/pi.sh
#    f) Long-press home screen → Widgets → Termux:Widget → pick pi.sh.
#
# 8. LAUNCH
#    pi         # interactive
#    pi --cron  # scheduled mode
#
# 9. UPDATING PI (after each release)
#    /quit                         # inside pi, if running
#    npm update -g @mariozechner/pi-coding-agent
#    pkg install which -y
#    termux-fix-shebang $(which pi)
#    # (the fix-shebang step is required after every npm update —
#    #  npm rewrites the bin shim with a non-Termux shebang.)
